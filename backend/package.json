  "description": "WhatsApp Blast Management System Backend",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "concurrently --kill-others --names \"API,WORKERS\" --prefix-colors \"blue,green\" \"nodemon src/index.js\" \"node src/workers/index.js\"",
    "dev:api": "nodemon src/index.js",
    "dev:workers": "node src/workers/index.js",
    "worker": "node src/workers/index.js",

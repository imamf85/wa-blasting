  "license": "ISC",
  "dependencies": {
    "@supabase/supabase-js": "^2.106.1",
    "axios": "^1.16.1",
    "bullmq": "^5.77.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "ioredis": "^5.10.1",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "uuid": "^14.0.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14"
  }
}

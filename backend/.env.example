# Supabase
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=your_service_key_here

# Redis (Railway will provide)
REDIS_URL=redis://localhost:6379

# WAHA
WAHA_API_BASE_URL=https://waha.yourdomain.com
WAHA_API_KEY=optional_if_needed

# App Config
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173

# Admin
ADMIN_WHATSAPP=087881847054

# Rate Limiting
GLOBAL_RATE_LIMIT_PER_MINUTE=10

# Health Check
HEALTH_CHECK_INTERVAL_MINUTES=5
ERROR_THRESHOLD_PER_HOUR=10

# Time-based greetings (optional, defaults to server timezone)
TIMEZONE=Asia/Jakarta

# Supabase Storage
SUPABASE_STORAGE_BUCKET=campaign-attachments
